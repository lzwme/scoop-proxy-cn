{
  "version": "9.9.30.260511.6a035910",
  "description": "A new version of Tencent QQ based on Electron.",
  "homepage": "https://im.qq.com/pcqq/index.shtml",
  "license": "Unknown",
  "notes": [
    "The app runtime is persisted by scoop, while user data is saved in path:",
    "\"$env:USERPROFILE\\Documents\\Tencent Files\""
  ],
  "depends": "Scoop4kariiin/Scoop4kariiinUtils",
  "architecture": {
    "64bit": {
      "url": "https://qqdl.gtimg.cn/qqfile/QQNT/9.9.30/guanwang/6a035910/QQ_9.9.30-260511_x64_01.exe#/dl.7z",
      "hash": "d32e291a220b9461697153be91a99a2b6f169ed33deb74a6de87d4770c8a32b3"
    },
    "32bit": {
      "url": "https://qqdl.gtimg.cn/qqfile/QQNT/9.9.30/guanwang/6a035910/QQ_9.9.30-260511_x86_01.exe#/dl.7z",
      "hash": "113bf9e4c3b98a101ca869caf1a00414bd2acdc2dd09db854667b2d3e3cc8116"
    },
    "arm64": {
      "url": "https://qqdl.gtimg.cn/qqfile/QQNT/9.9.30/guanwang/6a035910/QQ_9.9.30_260511_arm64_01.exe#/dl.7z",
      "hash": "9921311876b5f24e93036a130a76dec442dd6c8a66f58a7809ae8b1de6f942cc"
    }
  },
  "extract_dir": "Files",
  "installer": {
    "script": [
      "Import-Module -Name Scoop4kariiinUtils -ErrorAction Stop",
      "Mount-ExternalRuntimeData -Source \"$persist_dir\\QQ\" -AppData",
      "Remove-Module -Name Scoop4kariiinUtils -ErrorAction SilentlyContinue"
    ]
  },
  "shortcuts": [
    [
      "QQ.exe",
      "QQ"
    ]
  ],
  "uninstaller": {
    "script": [
      "Import-Module -Name Scoop4kariiinUtils -ErrorAction Stop",
      "Dismount-ExternalRuntimeData -Target \"QQ\" -AppData",
      "Remove-Module -Name Scoop4kariiinUtils -ErrorAction SilentlyContinue"
    ]
  },
  "checkver": {
    "script": [
      "$check_regex = [regex]\"guanwang\\/(\\w+)\\/QQ_([\\d.]+)-([\\d]+)_x86_01\\.exe\"",
      "$check_url = \"https://im.qq.com/proxy/domain/cdn-go.cn/qq-web/im.qq.com_new/latest/rainbow/pcConfig.json\"",
      "$check_page = Invoke-WebRequest -Uri $check_url -UseBasicParsing | Select-Object -ExpandProperty Content",
      "$check_page -match $check_regex | Out-Null",
      "$fetch_build_hash = $matches[1]",
      "$fetch_version_head = $matches[2]",
      "$fetch_version_tail = $matches[3]",
      "$fetch_version = ($fetch_version_head, $fetch_version_tail, $fetch_build_hash) -Join \".\"",
      "$current_version = $json.version",
      "$current_version_tail = $current_version -Split \"\\.\" | Select-Object -Last 1 -Skip 1",
      "if ([int]$fetch_version_tail -ge [int]$current_version_tail) {",
      "    return $fetch_version",
      "} else {",
      "    Write-Warning \"[TencentQQNT] Fetched latest version: $fetch_version, aborting update...\"",
      "    Write-Warning \"[TencentQQNT] Using current version: $current_version\"",
      "    return $current_version",
      "}"
    ],
    "regex": "([\\d.]+)\\.([\\d]+)\\.([\\w]+)",
    "replace": "${1}.${2}.${3}"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://qqdl.gtimg.cn/qqfile/QQNT/9.9.30/guanwang/$match3/QQ_$match1-$match2_x64_01.exe#/dl.7z"
      },
      "32bit": {
        "url": "https://qqdl.gtimg.cn/qqfile/QQNT/9.9.30/guanwang/$match3/QQ_$match1-$match2_x86_01.exe#/dl.7z"
      },
      "arm64": {
        "url": "https://qqdl.gtimg.cn/qqfile/QQNT/9.9.30/guanwang/$match3/QQ_$match1_$match2_arm64_01.exe#/dl.7z"
      }
    }
  }
}