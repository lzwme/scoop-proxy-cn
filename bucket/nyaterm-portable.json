  },
  "architecture": {
    "64bit": {
      "url": "https://github.com/nyakang/nyaterm/releases/download/v1.1.14/NyaTerm_1.1.14_windows_x64_portable.zip",
      "hash": "e8d9cb865715946b975d3eb727defbd2fff63a447527f494da819d7ea894274a"
    },
    "arm64": {
      "url": "https://github.com/nyakang/nyaterm/releases/download/v1.1.14/NyaTerm_1.1.14_windows_arm64_portable.zip",
      "hash": "5a6f3589a71d28d67b3c6c0708bcae4c54054c85e5ab1ffaf7d30f7878dc7318"
    }
  },
  "extract_dir": "NyaTerm-portable",
  "installer": {
    "script": [
      "# handle runtime cache",
      "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name spc) scripts/AppsUtils.psm1)",
      "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:USERPROFILE\\.nyaterm\"",
      "Remove-Module -Name AppsUtils"
    ]
  },
  "uninstaller": {
    "script": [
      "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name spc) scripts/AppsUtils.psm1)",
      "Dismount-ExternalRuntimeData -Target \"$env:USERPROFILE\\.nyaterm\"",
      "Remove-Module -Name AppsUtils"
    ]
  },
  "bin": "NyaTerm.exe",
  "shortcuts": [
    [
      "NyaTerm.exe",
      "NyaTerm"
    ]
  ],
  "checkver": {
    "github": "https://api.github.com/repos/nyakang/nyaterm/releases/latest",
    "jp": "$.tag_name",
    "regex": "v([\\d.]+)"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/nyakang/nyaterm/releases/download/v$version/NyaTerm_$version_windows_x64_portable.zip"
      },
      "arm64": {
        "url": "https://github.com/nyakang/nyaterm/releases/download/v$version/NyaTerm_$version_windows_arm64_portable.zip"
      }
    }
  }
}