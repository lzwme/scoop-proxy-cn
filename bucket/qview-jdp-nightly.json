  "architecture": {
    "arm64": {
      "url": "https://nightly.link/jdpurcell/qView/workflows/build/master/qView-JDP-2026-06-14.e6d3a3e-Windows_arm64.zip",
      "hash": "c91c2b4cb72a47abe384abfa4987c85b20ef30ffb453c98fe51a8e87313dac5d"
    },
    "64bit": {
      "url": "https://nightly.link/jdpurcell/qView/workflows/build/master/qView-JDP-2026-06-14.e6d3a3e-Windows_64.zip",
      "hash": "38e1b3a6fed69b6716e25e47c14c2d3854b69480b9d297890adc0360018c2feb"
    }
  },
  "pre_install": [
    "Get-ChildItem \"$dir\\qView-nightly-*.exe\" | Rename-Item -NewName { $_.name -Replace '-nightly.+', '.exe' }",
    "Remove-Item \"$dir\\qView-*.*-win*.exe\""
  ],
  "bin": "qView.exe",
  "shortcuts": [
    [
      "qView.exe",
      "qView"
    ]
  ],
  "checkver": {
    "script": [
      "try {",
      "    $api = (Invoke-RestMethod 'https://api.github.com/repositories/554598108/actions/workflows/build.yml/runs?branch=master&status=success&per_page=1' -Headers $(if ($auth = Get-GitHubToken) { @{authorization=\"Bearer $auth\"} })).workflow_runs[0]",
      "    ($api.id, (Get-Date $api.updated_at -Format 'yyyy-MM-dd'), $api.head_sha.Substring(0, 7)) -join ' '",
      "}",
      "catch { '' }"
    ],
    "regex": "\\A(\\d+) (?<date>\\d{4}(?:-\\d{2}){2}) (?<sha>[a-f\\d]{7})\\Z"
  },
  "autoupdate": {
    "architecture": {
      "arm64": {
        "url": "https://nightly.link/jdpurcell/qView/workflows/build/master/qView-JDP-$matchDate.$matchSha-Windows_arm64.zip",
        "hash": {
          "url": "https://api.github.com/repositories/554598108/actions/runs/$version/artifacts",
          "jsonpath": "$.artifacts[?(@.name == 'qView-JDP-$matchDate.$matchSha-Windows_arm64')].digest",
          "regex": "\\Asha256:$sha256\\Z"
        }
      },
      "64bit": {
        "url": "https://nightly.link/jdpurcell/qView/workflows/build/master/qView-JDP-$matchDate.$matchSha-Windows_64.zip",
        "hash": {
          "url": "https://api.github.com/repositories/554598108/actions/runs/$version/artifacts",
          "jsonpath": "$.artifacts[?(@.name == 'qView-JDP-$matchDate.$matchSha-Windows_64')].digest",
          "regex": "\\Asha256:$sha256\\Z"
        }
      }
    }
  }
}