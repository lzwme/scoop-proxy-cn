  "extract_dir": "{code_GetDestDir}",
  "innosetup": true,
  "post_install": [
    "if (!(Test-Path \"$dir\\data\\extensions\") -and (Test-Path \"$env:USERPROFILE\\.workbuddy\\extensions\")) {",
    "    info '[Portable Mode] Copying extensions...'",
    "    Copy-Item \"$env:USERPROFILE\\.workbuddy\\extensions\" \"$dir\\data\" -Recurse",
    "}",
    "if (!(Test-Path \"$dir\\data\\user-data\") -and (Test-Path \"$env:AppData\\WorkBuddy\")) {",
    "    info '[Portable Mode] Copying user data...'",
    "    Copy-Item \"$env:AppData\\WorkBuddy\" \"$dir\\data\\user-data\" -Recurse",
    "}",
    "$extensions_file = \"$dir\\data\\extensions\\extensions.json\"",
    "if ((Test-Path \"$extensions_file\")) {",
    "    info 'Adjusting path in extensions file...'",
    "    (Get-Content \"$extensions_file\") -replace '(?<=workbuddy(/|\\\\\\\\)).*?(?=(/|\\\\\\\\)data(/|\\\\\\\\)extensions)', $version | Set-Content \"$extensions_file\"",
    "}"
  ],
  "bin": [
    [
      "bin/workbuddy.cmd",
      "workbuddy"
    ]
  ],
  "shortcuts": [
    [
      "WorkBuddy.exe",
      "WorkBuddy"
    ]
  ],
  "persist": "data",
  "checkver": {
    "url": "https://www.codebuddy.cn/v2/update?platform=workbuddy-win32-x64-user",
    "jsonpath": "$.url",
    "regex": "(?<url>.*WorkBuddy-win32-x64-user-(?<version>[\\d.]+-[\\w.]+)\\.exe)"
  },
  "autoupdate": {
