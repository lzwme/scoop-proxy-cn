{
  "version": "0.7.2",
  "description": "A practical Douyin downloader for both single-item and profile batch downloads, with progress display, retries, SQLite deduplication, and browser fallback support. 抖音批量下载工具，去水印，支持视频、图集、合集、音乐(原声)。免费！免费！免费！",
  "homepage": "https://github.com/jiji262/douyin-downloader",
  "license": {
    "identifier": "MIT license",
    "url": "https://github.com/jiji262/douyin-downloader#MIT-1-ov-file"
  },
  "architecture": {
    "64bit": {
      "url": "https://github.com/jiji262/douyin-downloader/releases/download/desktop-v0.7.2/Douzy-Setup-0.7.2.exe#/dl.7z",
      "hash": "sha512:cc45418503f98c96ef65d77d91104ecfc01ee2a5b3af8984875d5a9369960733324f730cdcf87fd050d106556e8e8302f5a4910eef45697be36a437ba57fc3b4",
      "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
        "Remove-Item \"$dir\\`$*\" -Force -Recurse"
      ]
    }
  },
  "installer": {
    "script": [
      "# handle runtime cache",
      "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name spc) scripts/AppsUtils.psm1)",
      "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\douyin-downloader-desktop\"",
      "Remove-Module -Name AppsUtils"
    ]
  },
  "uninstaller": {
    "script": [
      "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name spc) scripts/AppsUtils.psm1)",
      "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\douyin-downloader-desktop\"",
      "Remove-Module -Name AppsUtils"
    ]
  },
  "bin": "Douzy.exe",
  "shortcuts": [
    [
      "Douzy.exe",
      "Douzy"
    ]
  ],
  "checkver": {
    "github": "https://api.github.com/repos/jiji262/douyin-downloader/releases",
    "jp": "$[0].tag_name",
    "regex": "desktop-v([\\d.]+)"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/jiji262/douyin-downloader/releases/download/desktop-v$version/Douzy-Setup-$version.exe#/dl.7z"
      }
    },
    "hash": {
      "url": "$baseurl/latest.yml",
      "regex": "(?sm)$basename.*?sha512:\\s+$base64"
    }
  }
}