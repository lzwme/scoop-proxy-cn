{
  "version": "1.8.8.1",
  "description": "Local Official Document Format Auto-Processing Tool",
  "homepage": "https://github.com/KaguraNanaga/docformat-gui",
  "license": "MIT",
  "depends": "uv",
  "url": "https://gh-proxy.org/https://github.com/KaguraNanaga/docformat-gui/archive/refs/tags/v1.8.8.1.zip",
  "hash": "9c2ddfdf18bb620db8d298774bc8dec7b8649c066d2f6af0f62417e029351b63",
  "extract_dir": "docformat-gui-1.8.8.1",
  "installer": {
    "script": [
      "Set-Location \"$dir\"",
      "uv init --bare",
      "uv add -r requirements.txt",
      "Set-Content \"$dir\\DocFormat.bat\" '@start uvw.exe run \"%~dp0\\docformat_gui.py\" %*' -Encoding ASCII"
    ]
  },
  "bin": "DocFormat.bat",
  "shortcuts": [
    [
      "DocFormat.bat",
      "DocFormat"
    ]
  ],
  "checkver": {
    "url": "https://api.github.com/repos/KaguraNanaga/docformat-gui/releases",
    "jsonpath": "$[0].tag_name",
    "regex": "v?([\\d.]+)"
  },
  "autoupdate": {
    "url": "https://gh-proxy.org/https://github.com/KaguraNanaga/docformat-gui/archive/refs/tags/v$version.zip",
    "extract_dir": "docformat-gui-$version"
  }
}