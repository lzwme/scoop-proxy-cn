  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/ShareX/DevBuilds/releases/download/v$version/ShareX-$version-portable-x64.zip"
      }
    },
    "hash": {
      "url": "https://github.com/ShareX/DevBuilds/releases/tag/v$version",
      "regex": "$basename</td>\\s*<td><code>$sha256</code>"
